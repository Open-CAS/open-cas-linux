      },
      "title": "Cache Usage",
      "type": "timeseries",
      "targets": [
        {
          "expr": "label_replace(opencas_cache_usage_clean_blocks{cache_id=~\"$cache_id\"} / (opencas_cache_usage_occupancy_blocks{cache_id=~\"$cache_id\"} + opencas_cache_usage_free_blocks{cache_id=~\"$cache_id\"}), \"type\", \"clean\", \"\", \"\") or label_replace(-(opencas_cache_usage_dirty_blocks{cache_id=~\"$cache_id\"} / (opencas_cache_usage_occupancy_blocks{cache_id=~\"$cache_id\"} + opencas_cache_usage_free_blocks{cache_id=~\"$cache_id\"})), \"type\", \"dirty\", \"\", \"\")",
          "legendFormat": "Cache {{cache_id}} {{type}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
