  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 100,
      "title": "Cache Instances",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "filterable": true,
            "align": "left"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Value"
            },
            "properties": [
              {
                "id": "custom.hidden",
                "value": true
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "cache_id"
            },
            "properties": [
              {
                "id": "custom.hidden",
                "value": true
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "type"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 80
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "id"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 60
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "status"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 100
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "cache line size (KiB)"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 120
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "cache size (GiB)"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 130
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "mode"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 70
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "cleaning policy"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 130
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "promotion policy"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 140
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "seq cutoff policy"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 140
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "seq cutoff threshold (KiB)"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 100
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 1
      },
      "id": 7,
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "cache_id",
            "desc": false
          },
          {
            "displayName": "type",
            "desc": false
          },
          {
            "displayName": "id",
            "desc": false
          }
        ]
      },
      "title": "Cache Instances",
      "type": "table",
      "targets": [
        {
          "expr": "label_replace(label_replace(label_replace(label_replace(opencas_cache_info, \"type\", \"cache\", \"\", \"\"), \"id\", \"$1\", \"cache_id\", \"(.+)\"), \"disk\", \"$1\", \"short_path\", \"(.+)\"), \"status\", \"$1\", \"state\", \"(.+)\")",
          "legendFormat": "",
          "refId": "A",
          "format": "table",
          "instant": true,
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        },
        {
          "expr": "label_replace(label_replace(label_replace(opencas_core_info, \"type\", \"core\", \"\", \"\"), \"id\", \"$1\", \"core_id\", \"(.+)\"), \"disk\", \"$1\", \"short_path\", \"(.+)\")",
          "legendFormat": "",
          "refId": "B",
          "format": "table",
          "instant": true,
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        },
        {
          "expr": "label_replace(opencas_cache_line_size_bytes / 1024, \"id\", \"$1\", \"cache_id\", \"(.+)\")",
          "legendFormat": "",
          "refId": "C",
          "format": "table",
          "instant": true,
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        },
        {
          "expr": "label_replace(opencas_cache_size_blocks * 4 / 1048576, \"id\", \"$1\", \"cache_id\", \"(.+)\")",
          "legendFormat": "",
          "refId": "D",
          "format": "table",
          "instant": true,
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        },
        {
          "expr": "label_replace(opencas_core_seq_cutoff_threshold_bytes / 1024, \"id\", \"$1\", \"core_id\", \"(.+)\")",
          "legendFormat": "",
          "refId": "E",
          "format": "table",
          "instant": true,
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {},
            "indexByName": {
              "cache_id": 0,
              "type": 1,
              "id": 2,
              "disk": 3,
              "status": 4,
              "Value #D": 5,
              "Value #C": 6,
              "mode": 7,
              "cleaning_policy": 8,
              "promotion_policy": 9,
              "seq_cutoff_policy": 10,
              "Value #E": 11
            },
            "includeByName": {
              "cache_id": true,
              "type": true,
              "id": true,
              "disk": true,
              "status": true,
              "Value #C": true,
              "Value #D": true,
              "mode": true,
              "cleaning_policy": true,
              "promotion_policy": true,
              "seq_cutoff_policy": true,
              "Value #E": true
            },
            "renameByName": {
              "Value #C": "cache line size (KiB)",
              "Value #D": "cache size (GiB)",
              "cleaning_policy": "cleaning policy",
              "promotion_policy": "promotion policy",
              "seq_cutoff_policy": "seq cutoff policy",
              "Value #E": "seq cutoff threshold (KiB)"
            }
          }
        }
      ]
    },
